// Star Atlas Sourcer — community asset bounty & review pipeline
// Data model for collab requests, submissions, votes, leaderboard, and admin settings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Auth + Users (NextAuth / Auth.js models + app fields)
// ─────────────────────────────────────────────────────────────

enum Role {
  MEMBER // community member: submit assets, upvote
  TEAM   // Star Atlas team: create requests, review submissions
  ADMIN  // full control: settings, GitHub config, manage roles
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  // Discord-specific display handle (set from the OAuth profile)
  username      String?
  role          Role      @default(MEMBER)
  points        Int       @default(0)
  createdAt     DateTime  @default(now())

  accounts    Account[]
  sessions    Session[]
  requests    CollabRequest[]   @relation("RequestAuthor")
  submissions Submission[]
  votes       Vote[]
  reviews     Submission[]      @relation("SubmissionReviewer")
  templates   RequestTemplate[]
  apiKeys     ApiKey[]
}

// API keys let team members create requests programmatically (via agents/scripts).
model ApiKey {
  id         String    @id @default(cuid())
  name       String
  ownerId    String
  hash       String    @unique // sha256 of the raw key — raw is shown once on creation
  prefix     String // first chars of the raw key, for display
  revoked    Boolean   @default(false)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────
// Collab requests (posted by the team)
// ─────────────────────────────────────────────────────────────

enum RequestStatus {
  DRAFT  // created (e.g. via agent/API) but not yet visible to the community
  OPEN
  CLOSED
}

model CollabRequest {
  id              String        @id @default(cuid())
  title           String
  description     String        @default("")
  assetType       String        @default("") // e.g. "Warp Drive", "Hull", "Engine"
  // Base file name for the accepted asset when committed to GitHub (extension added automatically).
  outputFileName  String        @default("")
  // How many images a submission must include (e.g. Tier 1-5 = 5). Capped at 5 by the app.
  imageCount      Int           @default(1)
  // Target platform(s) for the asset. At least one is required.
  targetWeb       Boolean       @default(true)
  targetUE5       Boolean       @default(false)
  tierMin         Int           @default(1)
  tierMax         Int           @default(5)
  // Reference background uploaded by the team for this request
  backgroundPath  String?
  // Spec template the community must match
  aspectRatio     String        @default("1:1")     // e.g. "16:9", "1:1"
  resolution      String        @default("1024x1024")
  format          String        @default("PNG")     // PNG / JPG / WEBP / SVG
  colorPalette    String        @default("")        // free-text guidance
  styleNotes      String        @default("")        // free-text guidance
  maxFileSizeMB   Int           @default(10)
  status          RequestStatus @default(OPEN)
  // True when created programmatically via the API (agent), for display/audit.
  createdViaApi   Boolean       @default(false)
  createdAt       DateTime      @default(now())

  authorId    String
  author      User         @relation("RequestAuthor", fields: [authorId], references: [id])
  submissions Submission[]
}

// ─────────────────────────────────────────────────────────────
// Reusable spec templates (saved by team members)
// ─────────────────────────────────────────────────────────────

model RequestTemplate {
  id            String   @id @default(cuid())
  name          String
  ownerId       String
  assetType     String   @default("")
  tierMin       Int      @default(1)
  tierMax       Int      @default(5)
  aspectRatio   String   @default("1:1")
  resolution    String   @default("1024x1024")
  format        String   @default("PNG")
  colorPalette  String   @default("")
  styleNotes    String   @default("")
  maxFileSizeMB Int      @default(10)
  createdAt     DateTime @default(now())

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────
// Submissions (posted by community members against a request)
// ─────────────────────────────────────────────────────────────

enum SubmissionStatus {
  PENDING       // gathering community upvotes
  TEAM_REVIEW   // crossed the upvote threshold; visible to the team
  ACCEPTED      // team accepted; author awarded a point; committed to GitHub
  REJECTED      // team rejected
}

model Submission {
  id          String           @id @default(cuid())
  requestId   String
  authorId    String
  title       String           @default("")
  notes       String           @default("")
  status      SubmissionStatus @default(PENDING)
  voteCount   Int              @default(0)
  // When the author accepted the ATMTA usage disclaimer at submit time (audit record).
  termsAcceptedAt DateTime?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime         @default(now())

  request    CollabRequest     @relation(fields: [requestId], references: [id], onDelete: Cascade)
  author     User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reviewedBy User?             @relation("SubmissionReviewer", fields: [reviewedById], references: [id])
  votes      Vote[]
  images     SubmissionImage[]
}

// One image within a submission. A request may ask for several (e.g. Tier 1-5 = 5 images).
model SubmissionImage {
  id           String   @id @default(cuid())
  submissionId String
  path         String
  position     Int      @default(0) // 0-based order; maps to tier when counts align
  // GitHub commit metadata once the submission is accepted
  committedSha String?
  committedUrl String?
  createdAt    DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

model Vote {
  id           String     @id @default(cuid())
  submissionId String
  userId       String
  createdAt    DateTime   @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([submissionId, userId]) // one vote per user per submission
}

// ─────────────────────────────────────────────────────────────
// Singleton admin settings
// ─────────────────────────────────────────────────────────────

model Settings {
  id               Int     @id @default(1)
  upvoteThreshold  Int     @default(10)
  // GitHub target for committing accepted assets
  githubOwner      String  @default("")
  githubRepo       String  @default("")
  githubBranch     String  @default("main")
  githubPathPrefix String  @default("assets") // folder within the repo
  // Default publish behavior for agent/API-created requests when they don't specify.
  agentAutoPublish Boolean @default(false)
  updatedAt        DateTime @updatedAt @default(now())
}
