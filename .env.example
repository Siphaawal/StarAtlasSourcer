# Copy to .env and fill in values.

DATABASE_URL="file:./dev.db"

AUTH_SECRET="generate-with: npx auth secret"
NEXTAUTH_URL="http://localhost:3000"

# Discord OAuth — https://discord.com/developers/applications
# Redirect URI: http://localhost:3000/api/auth/callback/discord
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Set "false" in production. Enables a no-Discord dev login for local testing.
ENABLE_DEV_LOGIN="true"

# GitHub PAT with repo contents:write. Target repo set in Admin dashboard.
GITHUB_TOKEN=""
